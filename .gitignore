# Create .gitignore content
@"
# Dependencies
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Environment variables
.env
.env.local
.env.production

# Build outputs
dist/
build/
.next/
out/

# IDE files
.vscode/
.idea/
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db

# Logs
logs/
*.log

# Temporary files
*.tmp
*.temp

# Database files
*.sqlite
*.db

# Server files
server/uploads/
server/temp/

# Client files
client/dist/
client/.vite/

# Backups
*.bak
*.backup
"@ | Out-File -FilePath .gitignore -Encoding utf8

Write-Host "✅ .gitignore created"